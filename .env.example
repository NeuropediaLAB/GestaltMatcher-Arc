# Example environment configuration for GestaltMatcher-Arc
# Copy this file to .env and configure for your deployment

# API Configuration
API_PORT=5000
WEB_PORT=8501

# Resource Limits (adjust based on your Raspberry Pi model)
# For 4GB RAM model, consider reducing to 1g
MEM_LIMIT=2g
CPU_LIMIT=2.0

# Number of API workers (1 is recommended for Raspberry Pi)
API_WORKERS=1

# Network Configuration
# Leave empty for default bridge network
NETWORK_NAME=gestaltmatcher-network
